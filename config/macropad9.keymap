/*
 * MacroPad9 — Keymap
 *
 * LAYER 0 (Base): Teclas del 1 al 9
 * LAYER 1 (Fn):   Controles Bluetooth / USB
 *
 * Para cambiar teclas reemplaza el código &kp XXXX.
 * Referencia completa: https://zmk.dev/docs/keymaps/key-press
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/outputs.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        /* ── LAYER 0 · Base ─────────────────────────────────────────
         *
         *  [ 1 ]  [ 2 ]  [ 3 ]
         *  [ 4 ]  [ 5 ]  [ 6 ]
         *  [ 7 ]  [ 8 ]  [ 9 ]
         *
         * Para activar Layer 1: mantén K9 (tecla "9")
         * y pulsa cualquier otra tecla de ese layer.
         * — O cambia &kp N9 por &mo 1 si prefieres una tecla dedicada.
         */
        base_layer {
            display-name = "Base";
            bindings = <
                &kp N1   &kp N2   &kp N3
                &kp N4   &kp N5   &kp N6
                &kp N7   &kp N8   &kp N9
            >;
        };

        /* ── LAYER 1 · Bluetooth/USB ─────────────────────────────────
         *
         *  [BT 0] [BT 1] [BT 2]    ← Seleccionar perfil BT (0-2)
         *  [BT 3] [BT 4] [BTCLR]   ← Perfiles 3-4 / Borrar pairing
         *  [ --- ] [USB] [BT/USB]   ← Salida USB / Toggle USB↔BT
         *
         * Para llegar aquí: añade &mo 1 en la tecla que quieras del Layer 0.
         * Ejemplo: cambia &kp N9 por &mo 1 en base_layer.
         */
        bt_layer {
            display-name = "BT";
            bindings = <
                &bt BT_SEL 0   &bt BT_SEL 1   &bt BT_SEL 2
                &bt BT_SEL 3   &bt BT_SEL 4   &bt BT_CLR
                &trans         &out OUT_USB    &out OUT_TOG
            >;
        };
    };
};
